# Required
DATABASE_URL=postgresql://kanban:CHANGE_ME@localhost:5432/kanban
POSTGRES_PASSWORD=CHANGE_ME

# Server
PORT=5000
NODE_ENV=production

# Railway: reference DATABASE_URL from the Postgres service; PORT is set automatically.
# Optional: GMAIL_INBOUND_WORKER_DISABLED=true when not using Gmail in this environment

# Gmail + Pub/Sub pipeline (optional — omit to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GMAIL_MAILBOX=
# GMAIL_LABEL_ID=
# GMAIL_PUBSUB_AUDIENCE=
# OPENAI_API_KEY=
# OPENAI_EMAIL_GRAPH_MODEL=gpt-4o-mini
# OPENAI_WEB_SEARCH_MODEL=gpt-4.1-mini
# OPENAI_WEB_SEARCH_TIMEOUT_MS=8000
# GMAIL_INBOUND_TRACE=true